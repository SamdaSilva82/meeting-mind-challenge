# Loaded by the API via @nestjs/config: this file, then optional `apps/api/.env`.
# Database
DATABASE_URL=postgres://meetingmind:meetingmind@localhost:5432/meetingmind

# Gemini configuration (real provider)
# Gemini key used by MeetingAnalysisService.
GOOGLE_API_KEY=
# Optional model override. Default is gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash

# API
API_PORT=3001

# Web
WEB_PORT=3000
API_URL=http://localhost:3001
